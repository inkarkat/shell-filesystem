#!/bin/bash

wrappedDatediff()
{
    DATEDIFF_COMMAND="$(basename "$0")" \
    DATEDIFF_WHAT='the (maximum) difference between the modification dates of FILE1 and FILE2 (and ...)' \
    DATEDIFF_INPUT_ARGS='[-f|--with-filename|-F|--with-file-dates OUTPUT-FORMAT] [--] FILE1 FILE2 [...]' \
    DATEDIFF_ADDITIONAL_OPTIONS='    -f|--with-filename	Append the oldest and youngest filespecs on separate
			lines (only one each).
    -F|--with-file-dates OUTPUT-FORMAT
			Append the file ages in the specified format on separate
			lines (only one each).
' \
    DATEDIFF_ADDITIONAL_EXIT_STATUS='    4	FILE does not exist.' \
    exec datediff "$@"
}

printUsage()
{
    wrappedDatediff --print-usage >&2
}

typeset -a datediffArgs=()
formatAddendum=
typeset filePrinter=(printf '%s\n')
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	wrappedDatediff "$@";;
	--with-filename|-f)
			shift; formatAddendum=$'\t%n';;
	--with-file-dates|-F)
			shift; formatAddendum=$'\t%n'; filePrinter=(fileAge --output "${1:?}" --with-filename); shift;;
	--)		shift; break;;
	-*)		if argCount=$(datediff --understands "$@"); then
			    while ((argCount-- > 0))
			    do
				datediffArgs+=("$1"); shift
			    done
			elif [ $? -eq 2 ]; then
			    exit 2
			else
			    { echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2
			fi
			;;
	*)		break;;
    esac
done
if [ $# -lt 2 ]; then
    printUsage "$0" >&2
    exit 2
fi

let maximumAge=0
let minimumAge=2147483647
for file
do
    fileAge="$(stat --dereference --format "%Y${formatAddendum}" -- "$file")" || exit 4
    if ((${fileAge%%$'\t'*} > ${maximumAge%%$'\t'*})); then
	maximumAge="$fileAge"
    fi
    if ((${fileAge%%$'\t'*} < ${minimumAge%%$'\t'*})); then
	minimumAge="$fileAge"
    fi
done

datediff "${datediffArgs[@]}" --no-direction "@${minimumAge%%$'\t'*}" "@${maximumAge%%$'\t'*}"; status=$?
[ -z "$formatAddendum" ] || "${filePrinter[@]}" "${minimumAge#*$'\t'}" "${maximumAge#*$'\t'}"
exit $status
