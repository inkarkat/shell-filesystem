#!/bin/bash

wrappedDatediff()
{
    DATEDIFF_COMMAND="$(basename "$0")" \
    DATEDIFF_WHAT='the age (time of last data modification) of all passed FILE(s)' \
    DATEDIFF_INPUT_ARGS='[-f|--with-filename] [--] FILE [...]' \
    DATEDIFF_ADDITIONAL_OPTIONS='    -f|--with-filename	Append a tab and the filespec to each line.
' \
    DATEDIFF_ADDITIONAL_EXIT_STATUS='    4	FILE does not exist.' \
    exec datediff "$@"
}

printUsage()
{
    wrappedDatediff --print-usage >&2
}

typeset -a datediffArgs=()
typeset -a datediffOutputArgs=()
formatAddendum=
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	wrappedDatediff "$@";;
	--with-filename|-f)
			shift; formatAddendum=$'\t%n';;
	--)		shift; break;;
	--output|-o)	datediffOutputArgs+=("$1" "${2:?}"); shift; shift;;
	-*)		if argCount=$(datediff --understands "$@"); then
			    while ((argCount-- > 0))
			    do
				datediffArgs+=("$1"); shift
			    done
			elif [ $? -eq 2 ]; then
			    exit 2
			else
			    { echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2
			fi
			;;
	*)		break;;
    esac
done
if [ $# -eq 0 ]; then
    printUsage "$0" >&2
fi
[ -n "$formatAddendum" ] && [ ${#datediffOutputArgs[@]} -eq 0 ] && datediffOutputArgs=(--output whole-units)

fileAges="$(stat --dereference --format "@%Y${formatAddendum}" -- "$@")" || exit 4
if [ $# -eq 1 -a -z "$formatAddendum" ]; then
    wrappedDatediff "${datediffArgs[@]}" "${datediffOutputArgs[@]}" "$fileAges"
else
    printf '%s\n' "$fileAges" | wrappedDatediff "${datediffArgs[@]}" "${datediffOutputArgs[@]}" --file=-
fi
